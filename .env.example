# Must match POSTGRES_PASSWORD below
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+asyncpg://kibrone:change_me@postgres:5432/kibrone
REDIS_URL=redis://redis:6379/0

# CRITICAL: сгенерируйте свой ключ — `openssl rand -hex 32`
SECRET_KEY=

# Окружение: dev / prod. В prod:
#   - webhook Zadarma без подписи → 401
#   - PDF без WeasyPrint → ошибка
#   - CORS только FRONTEND_URL
ENVIRONMENT=dev

# Создавать ли демо-аккаунты admin/manager/teacher при старте.
# Должно быть true ТОЛЬКО на dev/CI. В prod — false.
SEED_DEMO_USERS=true

# Сумма договора по умолчанию (₽/мес). Сервер ВСЕГДА берёт сумму отсюда,
# а не из тела intake-запроса, чтобы исключить подделку клиентом.
DEFAULT_CONTRACT_AMOUNT=5000.0

# Лимит брутфорса /auth/login: попыток на IP за 5 минут.
LOGIN_RATE_LIMIT_PER_5MIN=10

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
MANAGER_TELEGRAM_CHAT_ID=
ADMIN_TELEGRAM_CHAT_ID=

# Zadarma — в prod ZADARMA_SECRET обязателен (иначе webhook = 401)
ZADARMA_KEY=
ZADARMA_SECRET=

STORAGE_PATH=/app/storage
FRONTEND_URL=http://localhost:3000
